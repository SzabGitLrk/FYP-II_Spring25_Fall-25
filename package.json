{
  "name": "mindease",
  "version": "1.0.0",
  "description": "A comprehensive mental health platform with AI-powered chatbot and interactive quizzes",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build",
    "create-demo": "node scripts/createDemoUser.js",
    "seed:quizzes": "node scripts/createDefaultQuizzes.js",
    "test-chatbot": "node scripts/testChatbot.js",
    "test-email": "node scripts/testEmail.js",
    "test-forgot-password": "node scripts/testForgotPassword.js",
    "debug-email": "node scripts/debugEmail.js",
    "test-delivery": "node scripts/testEmailDelivery.js",
    "test-delivery-detailed": "node scripts/testEmailDeliveryDetailed.js",
    "test-forgot-with-user": "node scripts/testForgotPasswordWithUser.js",
    "test-empathetic-chatbot": "node scripts/testEmpatheticChatbot.js",
    "test-natural-chatbot": "node scripts/testNaturalChatbot.js"
  },
  "keywords": [
    "mental-health",
    "ai-chatbot",
    "therapy",
    "wellness"
  ],
  "author": "MindEase Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.12.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.10.1",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
